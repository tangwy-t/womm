<svg xmlns="http://www.w3.org/2000/svg" width="160" height="160" viewBox="0 0 160 160">
  <defs>
    <radialGradient id="bg-glow-{{.Badge.ID}}" cx="50%" cy="50%" r="65%">
      <stop offset="0%" stop-color="{{.Tier.Edge}}" stop-opacity="1"/>
      <stop offset="100%" stop-color="{{.Theme.BgColor}}" stop-opacity="1"/>
    </radialGradient>

    <radialGradient id="icon-glow-{{.Badge.ID}}" cx="50%" cy="45%" r="40%">
      <stop offset="0%" stop-color="{{.Tier.Glow}}" stop-opacity="0.45"/>
      <stop offset="55%" stop-color="{{.Tier.Glow}}" stop-opacity="0.10"/>
      <stop offset="100%" stop-color="{{.Tier.Glow}}" stop-opacity="0"/>
    </radialGradient>

    <linearGradient id="ring-{{.Badge.ID}}" x1="0" y1="0" x2="1" y2="1">
      <stop offset="0%" stop-color="{{.Tier.RingLight}}"/>
      <stop offset="50%" stop-color="{{.Tier.Accent}}"/>
      <stop offset="100%" stop-color="{{.Tier.RingDark}}"/>
    </linearGradient>
  </defs>

  <rect width="160" height="160" rx="8" fill="url(#bg-glow-{{.Badge.ID}})"/>
  <circle cx="80" cy="80" r="62" fill="url(#icon-glow-{{.Badge.ID}})"/>

  <g transform="translate(38,38)" color="{{.Tier.Accent}}">
    <svg width="84" height="84" viewBox="0 0 24 24">
      {{.Icon}}
    </svg>
  </g>

  <circle cx="80" cy="80" r="68" fill="none" stroke="url(#ring-{{.Badge.ID}})" stroke-width="5"/>
  <circle cx="80" cy="80" r="65" fill="none" stroke="{{.Tier.RingLight}}" stroke-width="0.5" opacity="0.6"/>

  {{if eq .Tier.Name "gold"}}
  <ellipse cx="60" cy="58" rx="18" ry="8" fill="#ffffff" opacity="0.12" transform="rotate(-25 60 58)"/>
  {{end}}
</svg>
